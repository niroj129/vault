# ===== Tiffany Gaming — deployment environment =====
# Copy to ".env" and fill in.  cp .env.example .env

# Public base URL that users visit. Same origin serves the site AND /api.
#   • before you have a domain:  http://YOUR_SERVER_IP
#   • with a domain + HTTPS:     https://yourdomain.com
PUBLIC_URL=http://YOUR_SERVER_IP

# Comma-separated hostnames Django will answer to (or * to allow all).
ALLOWED_HOSTS=*

# Django secret — generate once:
#   python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Postgres
POSTGRES_DB=tiffany
POSTGRES_USER=tiffany
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# Set to 1 only AFTER you've enabled HTTPS (otherwise logins break on http).
COOKIE_SECURE=0

# Seed demo data + admin/user accounts on first boot (set 0 after first deploy).
SEED=1
